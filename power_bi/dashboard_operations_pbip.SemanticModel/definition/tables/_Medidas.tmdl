	measure 'Downtime Planejado (hours)' =
			CALCULATE(
			    SUM('manufacturing_performance_analytics vw_fact_downtime_52w'[DowntimeDurationMin]),
			    'manufacturing_performance_analytics vw_fact_downtime_52w'[UnplannedFailure] = FALSE
			) / 60
