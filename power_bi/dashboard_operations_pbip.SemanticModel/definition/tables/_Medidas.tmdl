	measure 'PPM Defeitos' =
			VAR TotalDefeitos =
			    SUM('manufacturing_performance_analytics vw_fact_bottle_attribute_inspection_cq_52w'[DefectsFound])
			    + SUM('manufacturing_performance_analytics vw_fact_cap_attribute_inspection_cq_52w'[DefectsFound])
			    + SUM('manufacturing_performance_analytics vw_fact_ink_attribute_inspection_cq_52w'[DefectsFound])
			VAR TotalAmostra =
			    SUM('manufacturing_performance_analytics vw_fact_bottle_attribute_inspection_cq_52w'[SampleSize])
			    + SUM('manufacturing_performance_analytics vw_fact_cap_attribute_inspection_cq_52w'[SampleSize])
			    + SUM('manufacturing_performance_analytics vw_fact_ink_attribute_inspection_cq_52w'[SampleSize])
			RETURN
			    DIVIDE(TotalDefeitos, TotalAmostra) * 1000000
		formatString: 0
		displayFolder: Qualidade
		lineageTag: e9701ee7-6652-49a8-a18a-19cebb040c9c

	measure '% Cumprimento do Plano' =
			DIVIDE(
			    SUM(manufacturing_performance_fact_production[ProducedQty]),
