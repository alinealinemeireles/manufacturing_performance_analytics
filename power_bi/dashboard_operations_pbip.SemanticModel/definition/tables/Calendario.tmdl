	partition Calendario = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(DATE(2025,7,1), DATE(2026,7,31)),
				    "Ano", YEAR([Date]),
				    "MêsNum", MONTH([Date]),
				    "Mês", FORMAT([Date], "MMM"),
				    "SemanaISO", WEEKNUM([Date], 21),
				    "DiaSemana", FORMAT([Date], "ddd")
				)

	annotation PBI_Id = cc6357f51ec94599a153bfe9b1cdde78

