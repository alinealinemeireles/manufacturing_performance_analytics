# --- Large / regenerable datasets -----------------------------------------
# datasets/dim/ (governed master data, a few KB) IS versioned.
# datasets/raw/ and datasets/processed/ are regenerated by the notebooks
# (Etapa 1-3) and can be large (the two widest QC variable-inspection
# tables are 40-60 MB each) -- they are hosted on Google Drive instead of
# in git, see the "Data" section of the README for the links and the
# regeneration steps. Keeping folder structure with .gitkeep placeholders.
datasets/raw/*.csv
datasets/processed/*.csv
!datasets/raw/.gitkeep
!datasets/processed/.gitkeep

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
.env

# --- Jupyter ------------------------------------------------------------
*.ipynb_checkpoints

# --- OS / editor ----------------------------------------------------------
.DS_Store
.vscode/
*.swp

# --- Secrets ----------------------------------------------------------------
*.pem
credentials.json
